{
  "provider": "openrouter",
  "model": "openrouter/free",
  "api_key": "sk-or-v1-YOUR_OPENROUTER_API_KEY",
  "api_url": "https://openrouter.ai/api/v1/chat/completions",
  "headers": {
    "HTTP-Referer": "https://github.com/handoyokristanto-gif/Openclaw",
    "X-Title": "OpenClaw"
  },
  "recommended_models": [
    "openrouter/free",
    "google/gemini-2.0-flash-exp:free",
    "meta-llama/llama-3.1-8b-instruct:free",
    "mistralai/mistral-7b-instruct:free",
    "openrouter/auto"
  ],
  "setup_commands": [
    "openclaw onboard --auth-choice apiKey --token-provider openrouter --token YOUR_API_KEY",
    "openclaw models set openrouter/free"
  ],
  "notes": "PENTING: Pastikan variabel lingkungan OPENROUTER_API_KEY sudah diekspor. Gunakan format model 'openrouter/<provider>/<model>' agar OpenClaw mengenali plugin yang benar."
}
